{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "echo Static deploy — skip npm install",
  "buildCommand": "echo Static deploy — no bundle step",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*\\.(js|css))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
